# Why this exists: this is the production build/deploy template for the static
# frontend bundle and includes the publish directory used by the deploy script.
VITE_API_BASE_URL=https://api.example.com
VITE_ENABLE_JSON_SERVICES=true
VITE_ENABLE_BOOKS_SERVICES=true
VITE_MAX_UPLOAD_FILES=20
VITE_MAX_FILE_SIZE_MB=25
VITE_MAX_TOTAL_UPLOAD_MB=120
VITE_PAYPAL_DONATE_URL=https://www.paypal.com/donate/?business=YOUR_PAYPAL_ACCOUNT
DEPLOY_TARGET_DIR=/var/www/softaware-tools
