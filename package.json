{
  "name": "softaware-tools-portal",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "run": "vite --host 0.0.0.0",
    "build": "vite build",
    "typecheck": "vue-tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "preview": "vite preview",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier . --write",
    "format:check": "prettier . --check",
    "prepare": "husky"
  },
  "dependencies": {
    "bson": "^7.2.0",
    "fast-json-patch": "^3.1.1",
    "fast-xml-parser": "^5.4.2",
    "js-yaml": "^4.1.1",
    "jsondiffpatch": "^0.7.3",
    "jsonpath-plus": "^10.4.0",
    "jsonrepair": "^3.13.2",
    "jszip": "^3.10.1",
    "papaparse": "^5.5.3",
    "sql-formatter": "^15.7.2",
    "swagger-ui-dist": "^5.31.2",
    "vue": "^3.5.13"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^25.4.0",
    "@vitejs/plugin-vue": "^5.2.1",
    "@vue/tsconfig": "^0.9.0",
    "eslint": "^10.0.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-vue": "^10.8.0",
    "globals": "^17.3.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.2.7",
    "prettier": "^3.8.1",
    "sass": "^1.97.3",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.57.0",
    "vite": "^6.2.0",
    "vitest": "^4.0.18",
    "vue-tsc": "^3.2.5"
  },
  "lint-staged": {
    "*.{js,ts,vue}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,css,scss,md,html}": [
      "prettier --write"
    ]
  }
}
