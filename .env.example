# Why this exists: local frontend runs and production builds share the same
# Vite variable names, so this template keeps defaults visible without
# committing real deployment values.
VITE_API_BASE_URL=http://localhost:3000
VITE_ENABLE_JSON_SERVICES=true
VITE_ENABLE_BOOKS_SERVICES=true
VITE_MAX_UPLOAD_FILES=20
VITE_MAX_FILE_SIZE_MB=25
VITE_MAX_TOTAL_UPLOAD_MB=120
VITE_PAYPAL_DONATE_URL=https://www.paypal.com/donate/?business=QB59SY7LXPKDC
